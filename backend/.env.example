# ============================================
# CONFIGURAÇÕES DO SISTEMA - LOJA COMERCIAL
# ============================================
# Copie este arquivo para .env e preencha com seus dados

# --- Bling ---
# Acesse: app.bling.com.br → Preferências → API → Gerar Token
BLING_CLIENT_ID=SEU_CLIENT_ID_AQUI
BLING_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI
BLING_REDIRECT_URI=https://SEU_DOMINIO.railway.app/auth/bling/callback

# --- Segurança ---
# Gere uma chave aleatória: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_por_uma_chave_secreta_aleatoria

# --- Banco de dados ---
DATABASE_URL=sqlite:///./loja.db

# --- Configurações da Loja ---
NOME_LOJA=Minha Loja
META_PADRAO_MENSAL=12000
PERCENTUAL_COMISSAO=5.0
